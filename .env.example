# ============================================================================
# SafeSphere — Environment variables (template)
#
# Copy this file to `.env` and fill in your own values.
# See ENVIRONMENT.md for a full explanation of every variable.
# ============================================================================

# --- Supabase project ID (used by CLI tools) ---
SUPABASE_PROJECT_ID=
VITE_SUPABASE_PROJECT_ID=

# --- Supabase project URL (client-safe) ---
VITE_SUPABASE_URL=

# --- Supabase browser/public anon (publishable) key (client-safe) ---
VITE_SUPABASE_PUBLISHABLE_KEY=

# --- AI provider key — Google Gemini (SERVER ONLY, never exposed to browser) ---
# Get one from Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Production app URL (used for canonical links / SEO, e.g. sitemap) ---
VITE_APP_URL=

# --- Vapi AI Voice Calling System (SERVER ONLY) ---
VAPI_API_KEY=
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# ----------------------------------------------------------------------------
# Server-side mirrors of the Supabase credentials above.
# Server functions / SSR read process.env.SUPABASE_* (not the VITE_ names).
# Set these to the SAME values as the VITE_ ones above.
# ----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# --- Google Places API (New) Text Search Key (client-safe) ---
# Used for address autocomplete geocoding and routing destination suggestions.
# Enable "Places API" in Google Cloud Console.
VITE_GOOGLE_PLACES_API_KEY=

